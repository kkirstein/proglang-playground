with "config/benchmark_tests_config.gpr";
project Benchmark_Tests is

   for Source_Dirs use ("src/", "tests/");
   for Object_Dir use "obj/tests/" & Benchmark_Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Main use ("run_tests.adb");

   package Compiler is
      for Default_Switches ("Ada") use Benchmark_Tests_Config.Ada_Compiler_Switches;
   end Compiler;

end Benchmark_Tests;
